rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function validAlert() {
      let d = request.resource.data;
      return d.keys().hasAll(['timestamp', 'type', 'message', 'concernLevel'])
          && d.timestamp is number
          && d.type      is string && d.type.size()      <= 60
          && d.message   is string && d.message.size()   <= 500
          && d.concernLevel in ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL'];
    }

    // ── Documente familie root — nu se creează direct din app ────────────────
    match /families/{familyId} {
      allow read:  if isAuth();
      allow write: if false;
    }

    // ── Config la nivel de familie (ex. FCM token parinte) ───────────────────
    match /families/{familyId}/config/{doc} {
      allow read, write: if isAuth();
    }

    // ── Document copil + metadata (name) ─────────────────────────────────────
    match /families/{familyId}/children/{childId} {
      allow read, write: if isAuth();
    }

    // ── Setări trimise de parinte ─────────────────────────────────────────────
    match /families/{familyId}/children/{childId}/config/{doc} {
      allow read, write: if isAuth();
    }

    // ── Alerte — creare validată, fără update/delete ──────────────────────────
    match /families/{familyId}/children/{childId}/alerts/{alertId} {
      allow read:   if isAuth();
      allow create: if isAuth() && validAlert();
      allow update, delete: if false;
    }

    // ── Rapoarte zilnice ──────────────────────────────────────────────────────
    match /families/{familyId}/children/{childId}/reports/{reportId} {
      allow read:          if isAuth();
      allow create, update: if isAuth();
      allow delete:        if false;
    }

    // ── Profil wellbeing ──────────────────────────────────────────────────────
    match /families/{familyId}/children/{childId}/wellbeing/{doc} {
      allow read, write: if isAuth();
    }

    // ── Coduri de pairing ─────────────────────────────────────────────────────
    match /pairing/{code} {
      allow create: if isAuth()
                    && request.resource.data.keys().hasAll(['familyId', 'childId', 'childName', 'createdAt'])
                    && request.resource.data.createdAt  is number
                    && request.resource.data.familyId   is string
                    && request.resource.data.childId    is string
                    && request.resource.data.childName  is string
                    && request.resource.data.childName.size() <= 100;
      allow read:   if isAuth();
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["resolvedFamilyId"]);
      allow delete: if false;
    }

    // ── Feedback suport ───────────────────────────────────────────────────────
    match /feedback/{docId} {
      allow create: if isAuth()
                    && request.resource.data.message is string
                    && request.resource.data.message.size() <= 2000
                    && request.resource.data.category in ["Bug", "Sugestie", "Întrebare"];
      allow read, update, delete: if false;
    }

    // ── Orice altceva — blocat ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
